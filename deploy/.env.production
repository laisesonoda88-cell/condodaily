# CondoDaily — Variáveis de Produção
# ═══════════════════════════════════════════════
# INSTRUÇÕES:
# 1. Este arquivo é copiado para /opt/condodaily/.env no servidor
# 2. As chaves DB_PASSWORD, JWT_SECRET e ENCRYPTION_KEY já foram geradas
# 3. Preencha as variáveis do Mercado Pago e Anthropic
# 4. NUNCA commite o .env preenchido no git
# ═══════════════════════════════════════════════

# ─── Banco de Dados ────────────────────────────
DB_PASSWORD=d4e969492ffed6d49fda1e8a2443f5e1da8c8e160f8400af

# ─── Autenticação ──────────────────────────────
JWT_SECRET=cca88941a276d1e7871f0ddbf504aeca975845cabe661781338e96a0e7d854cec0feaf76113730b5aa4940a13e45abbb6126559bb5ea8f0508f036a7f2eb1876

# ─── Criptografia (AES-256-GCM) ───────────────
ENCRYPTION_KEY=800dc474cb04030d61c35e7c62d4f8f49a3dc08aec35e62dfbaec20b62e9117b

# ─── Mercado Pago ──────────────────────────────
# Painel: https://www.mercadopago.com.br/developers/panel/app
# ⚠ PREENCHER COM SUAS CREDENCIAIS DE PRODUÇÃO
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxx
MP_WEBHOOK_SECRET=webhook_secret_aqui

# ─── Anthropic (análise de documentos) ─────────
# https://console.anthropic.com/settings/keys
# ⚠ PREENCHER COM SUA API KEY
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ─── Email (Resend) ──────────────────────────
# Criar conta grátis: https://resend.com/signup
# Após verificar domínio condodaily.com.br, copiar API key
# Free tier: 100 emails/dia (suficiente pré-lançamento)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=CondoDaily <noreply@condodaily.com.br>

# ─── Admin Panel ─────────────────────────────
# Senha pra acessar o painel em condodaily.com.br/admin
# Gerar uma senha forte: openssl rand -hex 24
ADMIN_KEY=sua_senha_admin_aqui
