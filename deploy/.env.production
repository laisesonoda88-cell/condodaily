# CondoDaily — Variáveis de Produção
# ═══════════════════════════════════════════════
# INSTRUÇÕES:
# 1. Copie este arquivo para a raiz do projeto: cp deploy/.env.production .env
# 2. Preencha TODAS as variáveis abaixo
# 3. NUNCA commite o .env preenchido no git
# ═══════════════════════════════════════════════

# ─── Banco de Dados ────────────────────────────
DB_PASSWORD=TROCAR_POR_SENHA_FORTE_32_CHARS

# ─── Autenticação ──────────────────────────────
# Gerar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROCAR_POR_TOKEN_64_CHARS_ALEATORIO

# ─── Criptografia (AES-256-GCM) ───────────────
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=TROCAR_POR_CHAVE_32_BYTES_HEX

# ─── Mercado Pago ──────────────────────────────
# Painel: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxx
MP_WEBHOOK_SECRET=webhook_secret_aqui

# ─── Anthropic (análise de documentos) ─────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
