# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/condodaily

# ─── JWT (REQUIRED — min 32 chars, server won't start without it) ─
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-change-in-production

# ─── Encryption (REQUIRED — min 32 chars, AES-256-GCM for sensitive DB fields)
ENCRYPTION_KEY=your-encryption-key-min-32-characters-change-in-production

# ─── Server ────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ─── Mercado Pago (Payment Gateway) ───────────────────────
MP_ACCESS_TOKEN=your-mp-access-token
MP_PUBLIC_KEY=your-mp-public-key
MP_WEBHOOK_SECRET=your-mp-webhook-signature-secret
MP_ENV=sandbox

# ─── Anthropic (AI Document Analysis) ─────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── App ───────────────────────────────────────────────────
APP_URL=http://localhost:3001
